{
  "info": {
    "_postman_id": "agms-collection-2026-submission",
    "name": "AGMS - Submission Postman Collection",
    "description": "API tests for AGMS microservices through Gateway (except direct infrastructure checks).\n\nExecution order:\n1) Get JWT Token\n2) Create Zone\n3) Get Zone\n4) Trigger Automation\n5) Register/Update Crop\n6) Security + Infra checks",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "zone_id", "value": "", "type": "string" },
    { "key": "crop_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Get JWT Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('token', json.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"farmer1\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/token",
              "host": ["{{base_url}}"],
              "path": ["auth", "token"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Zone Service",
      "item": [
        {
          "name": "Create Zone",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.zoneId) {",
                  "  pm.collectionVariables.set('zone_id', json.zoneId);",
                  "}",
                  "pm.test('Response has zoneId', function () { pm.expect(json.zoneId).to.be.a('string'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tomato Zone A\",\n  \"minTemp\": 18,\n  \"maxTemp\": 30\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/zones",
              "host": ["{{base_url}}"],
              "path": ["api", "zones"]
            },
            "description": "Requires a valid external IoT bearer token configured in zone-service config for device registration."
          },
          "response": []
        },
        {
          "name": "Get Zone By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/zones/{{zone_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "zones", "{{zone_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Validation - Invalid Zone (minTemp >= maxTemp)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Invalid Zone\",\n  \"minTemp\": 30,\n  \"maxTemp\": 30\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/zones",
              "host": ["{{base_url}}"],
              "path": ["api", "zones"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Zone",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/zones/{{zone_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "zones", "{{zone_id}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Sensor Service",
      "item": [
        {
          "name": "Get Latest Telemetry",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/sensors/latest",
              "host": ["{{base_url}}"],
              "path": ["api", "sensors", "latest"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. Automation Service",
      "item": [
        {
          "name": "Trigger Action For Zone",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"TURN_FAN_ON\",\n  \"reason\": \"manual-test\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/automation/trigger/{{zone_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "automation", "trigger", "{{zone_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Get Automation State",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/automation/state",
              "host": ["{{base_url}}"],
              "path": ["api", "automation", "state"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "5. Crop Service",
      "item": [
        {
          "name": "Register Crop Batch",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('crop_id', json.id);",
                  "}",
                  "pm.test('Default status is SEEDLING', function () { pm.expect(json.status).to.eql('SEEDLING'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cherry Tomatoes\",\n  \"quantity\": 500,\n  \"zoneId\": \"{{zone_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/crops",
              "host": ["{{base_url}}"],
              "path": ["api", "crops"]
            }
          },
          "response": []
        },
        {
          "name": "Update Crop Status",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"VEGETATIVE\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/crops/{{crop_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["api", "crops", "{{crop_id}}", "status"]
            }
          },
          "response": []
        },
        {
          "name": "Get All Crops",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/crops",
              "host": ["{{base_url}}"],
              "path": ["api", "crops"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "6. Security & Infrastructure",
      "item": [
        {
          "name": "Security - No Token Should Be 401",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/crops",
              "host": ["{{base_url}}"],
              "path": ["api", "crops"]
            }
          },
          "response": []
        },
        {
          "name": "Security - Invalid Token Should Be 401",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer invalid.token.value" }
            ],
            "url": {
              "raw": "{{base_url}}/api/sensors/latest",
              "host": ["{{base_url}}"],
              "path": ["api", "sensors", "latest"]
            }
          },
          "response": []
        },
        {
          "name": "Eureka Dashboard (Direct)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8761",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8761"
            }
          },
          "response": []
        }
      ]
    }
  ]
}
